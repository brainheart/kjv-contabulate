[{"line_id": 1, "canonical_id": "ANT.3.8.1", "speaker": "CAESAR", "text": "Taurus!"}, {"line_id": 2, "canonical_id": "ANT.3.8.2", "speaker": "TAURUS", "text": "My lord?"}, {"line_id": 3, "canonical_id": "ANT.3.8.3", "speaker": "CAESAR", "text": "Strike not by land, keep whole. Provoke not battle"}, {"line_id": 4, "canonical_id": "ANT.3.8.4", "speaker": "CAESAR", "text": "Till we have done at sea. Do not exceed"}, {"line_id": 5, "canonical_id": "ANT.3.8.5", "speaker": "CAESAR", "text": "The prescript of this scroll."}, {"line_id": 6, "canonical_id": "ANT.3.8.6", "speaker": "CAESAR", "text": "Our fortune lies"}, {"line_id": 7, "canonical_id": "ANT.3.8.7", "speaker": "CAESAR", "text": "Upon this jump."}]