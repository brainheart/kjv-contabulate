[{"line_id": 1, "canonical_id": "ANT.4.5.1", "speaker": "SOLDIER", "text": "The gods make this a happy day to Antony."}, {"line_id": 2, "canonical_id": "ANT.4.5.2", "speaker": "ANTONY", "text": "Would thou and those thy scars had once prevailed"}, {"line_id": 3, "canonical_id": "ANT.4.5.3", "speaker": "ANTONY", "text": "To make me fight at land."}, {"line_id": 4, "canonical_id": "ANT.4.5.4", "speaker": "SOLDIER", "text": "Had’st thou done so,"}, {"line_id": 5, "canonical_id": "ANT.4.5.5", "speaker": "SOLDIER", "text": "The kings that have revolted and the soldier"}, {"line_id": 6, "canonical_id": "ANT.4.5.6", "speaker": "SOLDIER", "text": "That has this morning left thee would have still"}, {"line_id": 7, "canonical_id": "ANT.4.5.7", "speaker": "SOLDIER", "text": "Followed thy heels."}, {"line_id": 8, "canonical_id": "ANT.4.5.8", "speaker": "ANTONY", "text": "Who’s gone this morning?"}, {"line_id": 9, "canonical_id": "ANT.4.5.9", "speaker": "SOLDIER", "text": "Who?"}, {"line_id": 10, "canonical_id": "ANT.4.5.10", "speaker": "SOLDIER", "text": "One ever near thee. Call for Enobarbus,"}, {"line_id": 11, "canonical_id": "ANT.4.5.11", "speaker": "SOLDIER", "text": "He shall not hear thee, or from Caesar’s camp"}, {"line_id": 12, "canonical_id": "ANT.4.5.12", "speaker": "SOLDIER", "text": "Say “I am none of thine.”"}, {"line_id": 13, "canonical_id": "ANT.4.5.13", "speaker": "ANTONY", "text": "What sayest thou?"}, {"line_id": 14, "canonical_id": "ANT.4.5.14", "speaker": "SOLDIER", "text": "Sir,"}, {"line_id": 15, "canonical_id": "ANT.4.5.15", "speaker": "SOLDIER", "text": "He is with Caesar."}, {"line_id": 16, "canonical_id": "ANT.4.5.16", "speaker": "EROS", "text": "Sir, his chests and treasure"}, {"line_id": 17, "canonical_id": "ANT.4.5.17", "speaker": "EROS", "text": "He has not with him."}, {"line_id": 18, "canonical_id": "ANT.4.5.18", "speaker": "ANTONY", "text": "Is he gone?"}, {"line_id": 19, "canonical_id": "ANT.4.5.19", "speaker": "SOLDIER", "text": "Most certain."}, {"line_id": 20, "canonical_id": "ANT.4.5.20", "speaker": "ANTONY", "text": "Go, Eros, send his treasure after. Do it."}, {"line_id": 21, "canonical_id": "ANT.4.5.21", "speaker": "ANTONY", "text": "Detain no jot, I charge thee. Write to him—"}, {"line_id": 22, "canonical_id": "ANT.4.5.22", "speaker": "ANTONY", "text": "I will subscribe—gentle adieus and greetings."}, {"line_id": 23, "canonical_id": "ANT.4.5.23", "speaker": "ANTONY", "text": "Say that I wish he never find more cause"}, {"line_id": 24, "canonical_id": "ANT.4.5.24", "speaker": "ANTONY", "text": "To change a master. O, my fortunes have"}, {"line_id": 25, "canonical_id": "ANT.4.5.25", "speaker": "ANTONY", "text": "Corrupted honest men. Dispatch.—Enobarbus!"}]