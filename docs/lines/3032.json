[{"line_id": 1, "canonical_id": "ANT.4.7.1", "speaker": "AGRIPPA", "text": "Retire! We have engaged ourselves too far."}, {"line_id": 2, "canonical_id": "ANT.4.7.2", "speaker": "AGRIPPA", "text": "Caesar himself has work, and our oppression"}, {"line_id": 3, "canonical_id": "ANT.4.7.3", "speaker": "AGRIPPA", "text": "Exceeds what we expected."}, {"line_id": 4, "canonical_id": "ANT.4.7.4", "speaker": "SCARUS", "text": "O my brave emperor, this is fought indeed!"}, {"line_id": 5, "canonical_id": "ANT.4.7.5", "speaker": "SCARUS", "text": "Had we done so at first, we had droven them home"}, {"line_id": 6, "canonical_id": "ANT.4.7.6", "speaker": "SCARUS", "text": "With clouts about their heads."}, {"line_id": 7, "canonical_id": "ANT.4.7.7", "speaker": "ANTONY", "text": "Thou bleed’st apace."}, {"line_id": 8, "canonical_id": "ANT.4.7.8", "speaker": "SCARUS", "text": "I had a wound here that was like a T,"}, {"line_id": 9, "canonical_id": "ANT.4.7.9", "speaker": "SCARUS", "text": "But now ’tis made an H."}, {"line_id": 10, "canonical_id": "ANT.4.7.10", "speaker": "ANTONY", "text": "They do retire."}, {"line_id": 11, "canonical_id": "ANT.4.7.11", "speaker": "SCARUS", "text": "We’ll beat ’em into bench-holes. I have yet"}, {"line_id": 12, "canonical_id": "ANT.4.7.12", "speaker": "SCARUS", "text": "Room for six scotches more."}, {"line_id": 13, "canonical_id": "ANT.4.7.13", "speaker": "EROS", "text": "They are beaten, sir, and our advantage serves"}, {"line_id": 14, "canonical_id": "ANT.4.7.14", "speaker": "EROS", "text": "For a fair victory."}, {"line_id": 15, "canonical_id": "ANT.4.7.15", "speaker": "SCARUS", "text": "Let us score their backs"}, {"line_id": 16, "canonical_id": "ANT.4.7.16", "speaker": "SCARUS", "text": "And snatch ’em up as we take hares, behind."}, {"line_id": 17, "canonical_id": "ANT.4.7.17", "speaker": "SCARUS", "text": "’Tis sport to maul a runner."}, {"line_id": 18, "canonical_id": "ANT.4.7.18", "speaker": "ANTONY", "text": "I will reward thee"}, {"line_id": 19, "canonical_id": "ANT.4.7.19", "speaker": "ANTONY", "text": "Once for thy sprightly comfort and tenfold"}, {"line_id": 20, "canonical_id": "ANT.4.7.20", "speaker": "ANTONY", "text": "For thy good valor. Come thee on."}, {"line_id": 21, "canonical_id": "ANT.4.7.21", "speaker": "SCARUS", "text": "I’ll halt after."}]