[{"line_id": 1, "canonical_id": "MAC.1.1.1", "speaker": "FIRST\n               \n              WITCH", "text": "When shall we three meet again?"}, {"line_id": 2, "canonical_id": "MAC.1.1.2", "speaker": "FIRST\n               \n              WITCH", "text": "In thunder, lightning, or in rain?"}, {"line_id": 3, "canonical_id": "MAC.1.1.3", "speaker": "SECOND\n               \n              WITCH", "text": "When the hurly-burly’s done,"}, {"line_id": 4, "canonical_id": "MAC.1.1.4", "speaker": "SECOND\n               \n              WITCH", "text": "When the battle’s lost and won."}, {"line_id": 5, "canonical_id": "MAC.1.1.5", "speaker": "THIRD\n               \n              WITCH", "text": "That will be ere the set of sun."}, {"line_id": 6, "canonical_id": "MAC.1.1.6", "speaker": "FIRST\n               \n              WITCH", "text": "Where the place?"}, {"line_id": 7, "canonical_id": "MAC.1.1.7", "speaker": "SECOND\n               \n              WITCH", "text": "Upon the heath."}, {"line_id": 8, "canonical_id": "MAC.1.1.8", "speaker": "THIRD\n               \n              WITCH", "text": "There to meet with Macbeth."}, {"line_id": 9, "canonical_id": "MAC.1.1.9", "speaker": "FIRST\n               \n              WITCH", "text": "I come, Graymalkin."}, {"line_id": 10, "canonical_id": "MAC.1.1.10", "speaker": "SECOND\n               \n              WITCH", "text": "Paddock calls."}, {"line_id": 11, "canonical_id": "MAC.1.1.11", "speaker": "THIRD\n               \n              WITCH", "text": "Anon."}, {"line_id": 12, "canonical_id": "MAC.1.1.12", "speaker": "ALL", "text": "Fair is foul, and foul is fair;"}, {"line_id": 13, "canonical_id": "MAC.1.1.13", "speaker": "ALL", "text": "Hover through the fog and filthy air."}]